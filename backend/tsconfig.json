{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "*.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
