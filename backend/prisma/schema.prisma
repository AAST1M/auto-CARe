// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String
  name           String?
  phone          String?
  gender         String?
  dob            String?
  role           String        @default("USER") // USER, WINCH_DRIVER, WORKSHOP_OWNER
  walletBalance  Float         @default(0)
  resetToken     String?
  resetTokenExpiry DateTime?
  refreshToken   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  approvalStatus        String        @default("APPROVED") // PENDING, APPROVED, REJECTED
  commissionOwed        Float         @default(0) // Unpaid cash-ride commission debt (WINCH_DRIVER only)

  // Winch Driver specific fields
  licenseExpiry         String?
  plateNumber           String?
  criminalRecordCert    String?       // Base64 document
  driverPhoto           String?       // Base64 photo
  nationalIdCard        String?       // Base64 photo/doc

  // Workshop Owner specific fields
  taxCard               String?       // Base64 document
  workshopLocation      String?       // Coords or Address string
  ownerNationalIdCard   String?       // Base64 document
  workshopName          String?       // Workshop name if they want to create workshop directly

  // Customer specific fields
  userPlateNumber       String?
  userNationalId        String?
  carBrand              String?
  carModel              String?
  carYear               Int?
  chassisNumber         String?       // Optional
  carPhotoFront         String?       // Base64 photo
  carPhotoBack          String?       // Base64 photo
  carPhotoRight         String?       // Base64 photo
  carPhotoLeft          String?       // Base64 photo

  workshops      Workshop[]    @relation("OwnerWorkshops")
  appointments   Appointment[] @relation("UserAppointments")
  partOrders     PartOrder[]
  chats          ChatHistory[]
  transactionsAsUser Transaction[] @relation("UserTransactions")
  transactionsAsProvider Transaction[] @relation("ProviderTransactions")
  repairRequests RepairRequest[]
}

model Workshop {
  id            String        @id @default(uuid())
  ownerId       String
  name          String
  rating        Float         @default(0)
  distance      String?
  specialty     String?
  priceEstimate String?
  image         String?
  address       String?
  hours         String?
  services      String // Comma separated string for simplicity in SQLite, or JSON if supported
  description   String?
  latitude      Float?  // GPS coordinates
  longitude     Float?
  commercialRegister String? // Base64 commercial register document
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner         User          @relation("OwnerWorkshops", fields: [ownerId], references: [id])
  appointments  Appointment[] @relation("WorkshopAppointments")
  spareParts    SparePart[]
  repairBids    RepairBid[]
}

model Appointment {
  id            String   @id @default(uuid())
  userId        String
  workshopId    String
  serviceType   String
  carDetails    String?
  date          String?  // e.g. "2024-06-24"
  time          String   // e.g. "10:00"
  status        String   @default("Pending") // Pending, Confirmed, Checked-In, Completed, Cancelled
  progress      Int      @default(0) // 0 to 100 for live tracking
  price         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation("UserAppointments", fields: [userId], references: [id])
  workshop      Workshop @relation("WorkshopAppointments", fields: [workshopId], references: [id])
}

model WinchOffer {
  id            String   @id @default(uuid())
  driverId      String
  driverName    String
  price         Float
  eta           String
  rating        Float    @default(0)
  vehicle       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WinchBooking {
  id          String   @id @default(uuid())
  userId      String
  driverId    String
  driverName  String
  vehicle     String
  price       Float
  status      String   @default("Active") // Active, Accepted, En_Route, Arrived, Completed, Cancelled
  driverLat   Float?
  driverLng   Float?
  userLat     Float?
  userLng     Float?
  destLat     Float?
  destLng     Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SparePart {
  id                     String      @id @default(uuid())
  name                   String
  category               String
  price                  Float
  stock                  Int         @default(0)
  condition              String      @default("New") // New, Used
  image                  String?
  workshopId             String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  compatibilityModel     String?
  compatibilityYearStart Int?
  compatibilityYearEnd   Int?

  workshop               Workshop?   @relation(fields: [workshopId], references: [id])
  orders                 PartOrder[]
}

model PartOrder {
  id          String      @id @default(uuid())
  userId      String
  partId      String
  quantity    Int         @default(1)
  totalPrice  Float
  status      String      @default("Processing") // Processing, Shipped, Delivered, Cancelled
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  part        SparePart   @relation(fields: [partId], references: [id])
}

model ChatHistory {
  id          String   @id @default(uuid())
  userId      String
  role        String   // "user" or "model"
  content     String
  mediaType   String?  // e.g. "image/jpeg"
  mediaData   String?  // Base64 data if needed, or null if just text
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  providerId    String?
  amount        Float
  commission    Float    @default(0)
  type          String   // "Winch Ride", "Spare Part", "Workshop"
  status        String   @default("Completed")
  createdAt     DateTime @default(now())

  user          User     @relation("UserTransactions", fields: [userId], references: [id])
  provider      User?    @relation("ProviderTransactions", fields: [providerId], references: [id])
}

model RepairRequest {
  id          String   @id @default(uuid())
  userId      String
  carDetails  String
  issue       String
  imageUrl    String?  // Optional photo of the damage
  status      String   @default("Open") // Open, Accepted, Completed, Cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  bids        RepairBid[]
}

model RepairBid {
  id               String   @id @default(uuid())
  repairRequestId  String
  workshopId       String
  price            Float
  comment          String?
  status           String   @default("Pending") // Pending, Accepted, Rejected
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  repairRequest    RepairRequest @relation(fields: [repairRequestId], references: [id])
  workshop         Workshop      @relation(fields: [workshopId], references: [id])
}
